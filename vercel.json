{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "env": {
    "VITE_API_URL": "https://jefferson.alwaysdata.net"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
